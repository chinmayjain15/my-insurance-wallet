# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# -------------------------------------------------------

# "staging" | "production"
# In staging, any email is accepted (no real OAuth).
# In production, Google SSO via Supabase is used.
NEXT_PUBLIC_APP_ENV=staging

# Your app's public URL (used for OAuth redirects and referral links)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Amplitude — get this from your Amplitude project's Settings > Projects
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key-here

# Mixpanel — get this from your Mixpanel project's Settings > Project Token
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token-here

# RudderStack — get these from your RudderStack Source > Setup tab
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your-write-key-here
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://your-dataplane-url.dataplane.rudderstack.com

# PostHog — get the key from your PostHog project Settings > Project API key
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
