# -------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
# VERCEL DEPLOYMENT — mark vars tagged [SENSITIVE] as
# "Sensitive" in the Vercel dashboard (Settings > Environment
# Variables). Sensitive vars are encrypted at rest and hidden
# from logs. Non-sensitive vars are stored in plaintext and
# were exposed in the April 2025 Vercel breach.
# -------------------------------------------------------

# "staging" | "production"
# In staging, any email is accepted (no real OAuth).
# In production, Google SSO via Supabase is used.
NEXT_PUBLIC_APP_ENV=staging

# Your app's public URL (used for OAuth redirects and referral links)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # [SENSITIVE] — grants full DB access

# Amplitude — get this from your Amplitude project's Settings > Projects
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key-here

# Mixpanel — get this from your Mixpanel project's Settings > Project Token
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token-here

# RudderStack — get these from your RudderStack Source > Setup tab
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your-write-key-here
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://your-dataplane-url.dataplane.rudderstack.com

# PostHog — get the key from your PostHog project Settings > Project API key
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google OAuth — required for refreshing Gmail access tokens in Phase 3+
# Use the same Client ID / Secret configured in your Supabase Google provider settings.
# Get them from Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here    # [SENSITIVE] — OAuth client secret

# Anthropic — used as LLM fallback for policy classification when heuristics don't match.
# Get your key from console.anthropic.com > API Keys.
ANTHROPIC_API_KEY=your-anthropic-api-key-here           # [SENSITIVE] — billing-linked API key
